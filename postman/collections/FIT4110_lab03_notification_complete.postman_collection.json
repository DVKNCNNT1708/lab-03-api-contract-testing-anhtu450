  "item": [
    {
      "name": "Functional Tests",
      "item": [
        {
          "name": "POST /notifications - Create notification (Academic)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has notification id', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Response has type field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('type');",
                  "  pm.expect(json.type).to.equal('Academic');",
                  "});",
                  "",
                  "pm.test('Response has channel field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('channel');",
                  "  pm.expect(['EMAIL', 'SMS', 'PUSH', 'IN_APP']).to.include(json.channel);",
                  "});",
                  "",
                  "pm.test('Response time is under 2000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"SV123456\",\n  \"content\": \"Lớp Calculus 1 sẽ diễn ra vào lúc 8:00 AM ngày mai\",\n  \"type\": \"Academic\",\n  \"channel\": \"EMAIL\",\n  \"priority\": \"High\",\n  \"title\": \"Thông báo lớp học\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["notifications"]
            }
          }
