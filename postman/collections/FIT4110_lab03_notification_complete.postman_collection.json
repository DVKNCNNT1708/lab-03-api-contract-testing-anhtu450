    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Core -> Notification - Smoke POST /notifications",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 200', function () {",
                  "  pm.expect([200,201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Response has id and type', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('type');",
                  "});",
                  "",
                  "// store id for downstream checks",
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return {}; } })();",
                  "if (json && json.id) pm.environment.set('consumer_notification_id', json.id);",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"SV999999\",\n  \"content\": \"Core alert: sensor threshold exceeded\",\n  \"type\": \"Emergency\",\n  \"channel\": \"PUSH\",\n  \"priority\": \"High\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["notifications"]
            }
          }
        },
        {
          "name": "Core -> Notification - Dedup (Idempotency)",
